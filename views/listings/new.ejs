<% layout("/layouts/boilerplate") %>


    <div class="row justify-content-center mt-3">
        <div class="col-md-8">

            <h3>Create a New Listing</h3>
            <form method="POST" action="/listings" 
            novalidate class="needs-validation" 
            enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input name="listing[title]" class="form-control" required placeholder="Add a catchy title">
                    <div class="valid-feedback"> Title looks good</div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea name="listing[description]" class="form-control" rows="5" required></textarea>
                    <div class="invalid-feedback"> Please enter a short description</div>

                </div>

                
                <div class="mb-3">
                    <label class="form-label">Upload Listing Image</label>
                    <input name="listing[image]" type="file" class="form-control" required value="">
                </div>

                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label class="form-label">Price</label>
                        <input name="listing[price]" required class="form-control">
                        <div class="invalid-feedback"> Please enter a valid Price</div>

                    </div>

                    <div class="mb-3 col-md-8">
                        <label class="form-label">Country</label>
                        <input name="listing[country]" class="form-control" required>
                        <div class="invalid-feedback"> Please enter a valid Country</div>

                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Location</label>
                    <input name="listing[location]" required class="form-control">
                    <div class="invalid-feedback"> Please enter a valid location</div>

                </div>
                <br>
                <button class="btn btn-dark add-btn mt-3 mb-3">Add</button>

            </form>

        </div>
    </div>